# Copy to backend/.env and fill in.

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=0
ALLOWED_HOSTS=*

# Comma-separated list, or "*" to allow all origins.
CORS_ALLOWED_ORIGINS=https://your-lovable-app.lovable.app,http://localhost:8080

# Optional shared secret. If set, frontend must send X-API-Key: <this value>.
API_KEY=

# Public URL where this Django server is reachable (used to build /media/... links from /api/convert/).
PUBLIC_BASE_URL=https://your-django-host.example.com

# Optional — mitigate YouTube rate limits on shared hosts.
# YTDLP_COOKIES_FILE=/app/cookies.txt
# YTDLP_PROXY=http://user:pass@proxy.example.com:8080

# Where converted files land. Defaults to /tmp/ytdlp-media.
# MEDIA_ROOT=/tmp/ytdlp-media
